{
  "main": "index.js",
  "types": "index.d.ts",
  "scripts": {},
  "files": [
    "**"
  ],
  "name": "@algorandfoundation/algokit-utils",
  "version": "10.0.0-alpha.42",
  "private": false,
  "description": "A set of core Algorand utilities written in TypeScript and released via npm that make it easier to build solutions on Algorand.",
  "author": "Algorand Foundation",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/algorandfoundation/algokit-utils-ts.git"
  },
  "engines": {
    "node": ">=20.0"
  },
  "type": "commonjs",
  "module": "index.mjs",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.mjs",
      "require": "./index.js"
    },
    "./types/*": {
      "types": "./types/*.d.ts",
      "import": "./types/*.mjs",
      "require": "./types/*.js"
    },
    "./testing": {
      "types": "./testing/index.d.ts",
      "import": "./testing/index.mjs",
      "require": "./testing/index.js"
    },
    "./abi": {
      "types": "./abi/index.d.ts",
      "import": "./abi/index.mjs",
      "require": "./abi/index.js"
    },
    "./transact": {
      "types": "./transact/index.d.ts",
      "import": "./transact/index.mjs",
      "require": "./transact/index.js"
    },
    "./transaction": {
      "types": "./transaction/index.d.ts",
      "import": "./transaction/index.mjs",
      "require": "./transaction/index.js"
    },
    "./algod-client": {
      "types": "./algod-client/index.d.ts",
      "import": "./algod-client/index.mjs",
      "require": "./algod-client/index.js"
    },
    "./indexer-client": {
      "types": "./indexer-client/index.d.ts",
      "import": "./indexer-client/index.mjs",
      "require": "./indexer-client/index.js"
    },
    "./kmd-client": {
      "types": "./kmd-client/index.d.ts",
      "import": "./kmd-client/index.mjs",
      "require": "./kmd-client/index.js"
    },
    "./algo25": {
      "types": "./algo25/index.d.ts",
      "import": "./algo25/index.mjs",
      "require": "./algo25/index.js"
    },
    "./crypto": {
      "types": "./crypto/index.d.ts",
      "import": "./crypto/index.mjs",
      "require": "./crypto/index.js"
    },
    "./common": {
      "types": "./common/index.d.ts",
      "import": "./common/index.mjs",
      "require": "./common/index.js"
    },
    "./*": {
      "types": "./*.d.ts",
      "import": "./*.mjs",
      "require": "./*.js"
    },
    "./index.d.ts": "./index.d.ts",
    "./package.json": "./package.json"
  },
  "overrides": {
    "esbuild": "0.25.0"
  },
  "dependencies": {
    "@algorandfoundation/xhd-wallet-api": "2.0.0-canary.1",
    "@noble/curves": "^2.0.1",
    "@noble/ed25519": "^3.0.0",
    "@noble/hashes": "^2.0.1",
    "algorand-msgpack": "^1.1.0",
    "buffer": "^6.0.3",
    "dotenv": "^16.4.5",
    "hi-base32": "^0.5.1",
    "json-bigint": "^1.0.0",
    "tweetnacl": "^1.0.3",
    "vlq": "^2.0.4"
  }
}
